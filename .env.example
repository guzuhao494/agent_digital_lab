OPENCLAW_MODE=local

# Recommended: call LLM through NUWA:
# OPENCLAW_MODE=nuwa
# NUWA_API_KEY=replace-with-your-key
# NUWA_BASE_URL=https://api.nuwaflux.com/v1
# NUWA_MODEL=gpt-4o-mini
#
# Generic OpenAI-compatible gateway is also supported:
# OPENCLAW_MODE=llm
# OPENCLAW_LLM_API_KEY=replace-with-your-key
# OPENCLAW_LLM_BASE_URL=https://api.openai.com/v1
# OPENCLAW_LLM_MODEL=gpt-4o-mini
# OPENCLAW_LLM_TIMEOUT_SECONDS=25
# OPENCLAW_LLM_TEMPERATURE=0.18
